<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="QuizMaster"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuizMaster">

        <!-- HOME -->
        <activity android:name=".HomeActivity" />

        <!-- LOGIN -->
        <activity android:name=".LoginActivity" />

        <!-- CATEGORY -->
        <activity android:name=".CategoryActivity" />

        <!-- LEADERBOARD -->
        <activity android:name=".LeaderboardActivity" />

        <!-- START (Parent Activity) -->
        <activity android:name=".StartActivity" />

        <!-- ✅ DEVICE INFO (ADD THIS) -->
        <activity
            android:name=".DeviceInfoActivity"
            android:parentActivityName=".StartActivity" />

        <!-- ✅ SENSOR TEST (ADD THIS) -->
        <activity
            android:name=".SensorTestActivity"
            android:parentActivityName=".StartActivity" />

        <!-- SPLASH (LAUNCHER) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>