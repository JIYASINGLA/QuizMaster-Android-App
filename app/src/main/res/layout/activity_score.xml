<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA">

    <!-- Score Circle -->
    <FrameLayout
        android:id="@+id/scoreCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/score_outer_circle"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Inner Circle -->
        <LinearLayout
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/score_inner_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtScoreTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Score"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textAlignment="center"/>

            <TextView
                android:id="@+id/txtScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09/10"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="38sp"
                android:textAlignment="center"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Congratulations -->
    <TextView
        android:id="@+id/txtCongrats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Congratulation"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1F4E9E"
        android:textAlignment="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/scoreCircle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Message -->
    <TextView
        android:id="@+id/txtMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Great job! You Did It"
        android:textSize="16sp"
        android:textColor="#3B4A6B"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtCongrats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Next Button -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Next"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:background="@drawable/button_background"
        android:onClick="nextQuiz"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/txtMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Home Button -->
    <Button
        android:id="@+id/btnHome"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Back to Home"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:background="@drawable/button_background"
        android:onClick="goHome"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>